{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/hook-ai-mission.sh",
            "statusMessage":"[AI项目主权声明已注入]"
          }
        ]
      },
       {
               "matcher": "compact",
               "hooks": [
                 {
                   "type": "command",
                   "command": "bash .claude/scripts/hook-ai-mission.sh",
                   "statusMessage":"[AI项目主权声明已注入]"
                 }
               ]
             }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/scripts/hook-block-sensitive.py"
          }
        ]
      }
    ]
  }
}
