{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/scripts/hook-sprite-sync.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/hook-ts-counter.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/scripts/hook-block-sensitive.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/scripts/hook-stop-check.py"
          }
        ]
      }
    ]
  }
}
